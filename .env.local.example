# Frontend environment variables
#
# Copy to `.env.local` for local development:
#   cp .env.local.example .env.local
#
# NEXT_PUBLIC_API_BASE_URL — Base URL for the FastAPI backend (including /api/v1).
# Used by the Axios client in lib/axios.ts. Must be prefixed with NEXT_PUBLIC_
# so it is available in the browser bundle.
#
# NEXT_PUBLIC_INSIGHT_GENERATE_TIMEOUT_MS — Per-request timeout (ms) for
# POST /interactions/{id}/generate-insight only. Should exceed the global Axios
# timeout (30s) so LLM generation can finish. Defaults to 120000 if unset.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_INSIGHT_GENERATE_TIMEOUT_MS=120000
